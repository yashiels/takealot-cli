{
  "name": "takealot-cli",
  "version": "0.1.1",
  "description": "Command-line tool for Takealot.com — search, cart, pure-API checkout, and order history.",
  "type": "module",
  "bin": {
    "takealot": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "fmt": "prettier --write .",
    "clean": "rm -rf dist",
    "start": "node dist/cli.js",
    "prepublishOnly": "npm run clean && npm run build"
  },
  "keywords": [
    "takealot",
    "cli",
    "shopping",
    "south-africa"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "prettier": "^3.8.4",
    "typescript": "^5.7.0",
    "vitest": "^4.1.8"
  }
}
